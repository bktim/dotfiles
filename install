#!/usr/bin/env bash
set -euo pipefail

case ${BASH_SOURCE[0]} in
  */*) repo_dir=${BASH_SOURCE[0]%/*} ;;
  *) repo_dir=. ;;
esac
repo_dir=$(CDPATH= cd -- "$repo_dir" && pwd)
verify_only=false
chezmoi_args=()
minimum_nvim_version="0.11.2"

source "$repo_dir/lib/install/common.sh"
source "$repo_dir/lib/install/package_managers.sh"
source "$repo_dir/lib/install/tools.sh"
source "$repo_dir/lib/install/verify.sh"

usage() {
  printf '%s\n' \
    'Usage: ./install [--verify-only] [chezmoi init args...]' \
    '' \
    'Options:' \
    '  --verify-only  Skip installation and chezmoi apply; only run verification checks' \
    '  -h, --help     Show this help message'
}

parse_args() {
  while (($# > 0)); do
    case $1 in
      --verify-only)
        verify_only=true
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        chezmoi_args+=("$1")
        ;;
    esac
    shift
  done
}

bootstrap_path() {
  if [[ -z "${PATH:-}" ]]; then
    PATH="/usr/bin:/bin:/usr/sbin:/sbin"
  fi

  prepend_path_if_dir /opt/homebrew/bin
  prepend_path_if_dir /usr/local/bin
  prepend_path_if_dir /usr/bin
  prepend_path_if_dir /bin
  prepend_path_if_dir /usr/sbin
  prepend_path_if_dir /sbin
  export PATH
}

main() {
  parse_args "$@"
  bootstrap_path

  if [[ ${EUID:-$(id -u)} -eq 0 ]]; then
    printf 'do not run ./install with sudo; it must run as your normal user\n' >&2
    printf 'on macOS, Homebrew may still prompt for your password when needed\n' >&2
    exit 1
  fi

  if [[ $verify_only == true ]]; then
    prepend_path_if_dir "$HOME/.cargo/bin"
    prepend_path_if_dir "$HOME/.opencode/bin"
    prepend_path_if_dir "$HOME/bin"
    prepend_path_if_dir "$HOME/.local/bin"
    check_neovim_health
    verify_tools
    log "Verification complete"
    return
  fi

  install_packages
  set_login_shell_bash
  install_neovim
  install_chezmoi
  install_opencode
  install_nvm
  install_rust_toolchain

  if ! need_cmd chezmoi; then
    printf 'missing required command after bootstrap: chezmoi\n' >&2
    exit 1
  fi

  log "Applying dotfiles with chezmoi"
  chezmoi init "$repo_dir" 2>/dev/null || true
  local cmd=(chezmoi apply --source "$repo_dir")
  if ((${#chezmoi_args[@]} > 0)); then
    cmd+=("${chezmoi_args[@]}")
  fi
  "${cmd[@]}"
  sync_neovim_plugins
  check_neovim_health
  verify_tools

  log "Setup complete"
}

main "$@"
