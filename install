#!/usr/bin/env bash
set -euo pipefail

repo_dir=$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
target_dir=${TARGET:-"$HOME"}
packages=(shell git tmux nvim bin)

for cmd in stow; do
  command -v "$cmd" >/dev/null 2>&1 || {
    printf 'missing required command: %s\n' "$cmd" >&2
    exit 1
  }
done

if [[ $# -gt 0 ]]; then
  packages=("$@")
fi

prepare_package() {
  local package source_path rel_path target_path target_realpath

  package=$1
  while IFS= read -r source_path; do
    rel_path=${source_path#"$repo_dir/$package/"}
    target_path="$target_dir/$rel_path"

    if target_realpath=$(readlink -f "$target_path" 2>/dev/null); then
      case "$target_realpath" in
        "$repo_dir"/*) continue ;;
      esac
    fi

    if [[ -e "$target_path" && ! -L "$target_path" && ! -d "$target_path" ]]; then
      mv "$target_path" "$target_path.pre-dotfiles"
    fi
  done < <(find "$repo_dir/$package" \( -type f -o -type l \))
}

for package in "${packages[@]}"; do
  prepare_package "$package"
  stow --dir "$repo_dir" --target "$target_dir" --restow "$package"
done
