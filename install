#!/usr/bin/env bash
set -euo pipefail

repo_dir=$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
verify_only=false
chezmoi_args=()
minimum_nvim_version="0.11.2"

source "$repo_dir/lib/install/common.sh"
source "$repo_dir/lib/install/package_managers.sh"
source "$repo_dir/lib/install/tools.sh"
source "$repo_dir/lib/install/verify.sh"

usage() {
  cat <<'EOF'
Usage: ./install [--verify-only] [chezmoi init args...]

Options:
  --verify-only  Skip installation and chezmoi apply; only run verification checks
  -h, --help     Show this help message
EOF
}

parse_args() {
  while (($# > 0)); do
    case $1 in
      --verify-only)
        verify_only=true
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        chezmoi_args+=("$1")
        ;;
    esac
    shift
  done
}

bootstrap_path() {
  if [[ -z "${PATH:-}" ]]; then
    PATH="/usr/bin:/bin:/usr/sbin:/sbin"
  fi

  append_path_if_dir /opt/homebrew/bin
  append_path_if_dir /usr/local/bin
  append_path_if_dir /usr/bin
  append_path_if_dir /bin
  append_path_if_dir /usr/sbin
  append_path_if_dir /sbin
  export PATH
}

main() {
  parse_args "$@"
  bootstrap_path

  if [[ ${EUID:-$(id -u)} -eq 0 ]]; then
    printf 'do not run ./install with sudo; it must run as your normal user\n' >&2
    printf 'on macOS, Homebrew may still prompt for your password when needed\n' >&2
    exit 1
  fi

  if [[ $verify_only == true ]]; then
    append_path_if_dir "$HOME/.cargo/bin"
    append_path_if_dir "$HOME/.opencode/bin"
    append_path_if_dir "$HOME/bin"
    append_path_if_dir "$HOME/.local/bin"
    check_neovim_health
    verify_tools
    log "Verification complete"
    return
  fi

  install_packages
  install_neovim
  install_chezmoi
  install_opencode
  install_nvm
  install_rust_toolchain

  if ! need_cmd chezmoi; then
    printf 'missing required command after bootstrap: chezmoi\n' >&2
    exit 1
  fi

  log "Applying dotfiles with chezmoi"
  chezmoi init --apply "$repo_dir" "${chezmoi_args[@]}"
  sync_neovim_plugins
  check_neovim_health
  verify_tools

  log "Setup complete"
}

main "$@"
